<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:FmlDiff.ViewModels"
        x:Class="FmlDiff.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Title="FML Hex Diff Viewer"
        Width="1600"
        Height="900"
        MinWidth="1200"
        MinHeight="700">
  <Window.Styles>
    <Style Selector="ListBoxItem">
      <Setter Property="Foreground" Value="#E8EAF0" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="#253146" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="#2E5FA8" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,220">
    <Border Grid.Row="0"
            BorderBrush="#404040"
            BorderThickness="0,0,0,1"
            Padding="10">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
          <TextBlock VerticalAlignment="Center" Text="File A" />
          <TextBox Grid.Column="1" Text="{Binding FileAPath}" />
          <Button Grid.Column="2"
                  Content="Browse..."
                  Click="OpenFileAClick"
                  IsEnabled="{Binding CanRun}" />
        </Grid>

        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
          <TextBlock VerticalAlignment="Center" Text="File B" />
          <TextBox Grid.Column="1" Text="{Binding FileBPath}" />
          <Button Grid.Column="2"
                  Content="Browse..."
                  Click="OpenFileBClick"
                  IsEnabled="{Binding CanRun}" />
        </Grid>

        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*"
              ColumnSpacing="8">
          <Button Grid.Column="0"
                  Content="Load &amp;&amp; Diff"
                  Click="RunDiffClick"
                  IsEnabled="{Binding CanRun}" />
          <Button Grid.Column="1"
                  Content="Previous"
                  Click="PreviousDifferenceClick"
                  IsEnabled="{Binding CanNavigate}" />
          <Button Grid.Column="2"
                  Content="Next"
                  Click="NextDifferenceClick"
                  IsEnabled="{Binding CanNavigate}" />
          <TextBlock Grid.Column="3"
                     VerticalAlignment="Center"
                     Foreground="#E8EAF0"
                     Text="{Binding DifferenceNavigatorText}" />
          <TextBlock Grid.Column="4"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Foreground="#C7CDD8"
                     Text="Changed bytes are highlighted in red" />
        </Grid>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Background="#222A35"
            BorderBrush="#404040"
            BorderThickness="0,0,0,1"
            Padding="8,6">
      <TextBlock Foreground="#E8EAF0" Text="{Binding StatusMessage}" />
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="*,*"
          ColumnSpacing="10"
          Margin="10">
      <Border Grid.Column="0"
              BorderBrush="#404040"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,*">
          <Border BorderBrush="#404040"
                  BorderThickness="0,0,0,1"
                  Padding="8,6">
            <TextBlock FontWeight="Bold" Text="Pane A (raw hex)" />
          </Border>

          <ListBox x:Name="LeftListBox"
                   Grid.Row="1"
                   ItemsSource="{Binding LeftRows}"
                   SelectedIndex="{Binding SelectedRowIndex}"
                   Background="#171C26"
                   BorderThickness="0"
                   SelectionMode="Single">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:HexDumpRowViewModel">
                <Border Background="{Binding RowBackground}" Padding="6,1" Height="24">
                  <Grid ColumnDefinitions="90,430,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0"
                               FontFamily="Consolas"
                               FontSize="14"
                               Foreground="#D6DBE6"
                               Text="{Binding OffsetText}" />
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding HexCells}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:HexByteCellViewModel">
                          <Border Margin="0,0,2,0"
                                  Padding="1,0"
                                  Height="20"
                                  Background="{Binding Background}">
                            <TextBlock FontFamily="Consolas"
                                       FontSize="14"
                                       Foreground="{Binding Foreground}"
                                       Text="{Binding Text}" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Grid.Column="2"
                               FontFamily="Consolas"
                               FontSize="14"
                               Foreground="#D0D6E1"
                               Text="{Binding AsciiText}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              BorderBrush="#404040"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,*">
          <Border BorderBrush="#404040"
                  BorderThickness="0,0,0,1"
                  Padding="8,6">
            <TextBlock FontWeight="Bold" Text="Pane B (raw hex)" />
          </Border>

          <ListBox x:Name="RightListBox"
                   Grid.Row="1"
                   ItemsSource="{Binding RightRows}"
                   SelectedIndex="{Binding SelectedRowIndex}"
                   Background="#171C26"
                   BorderThickness="0"
                   SelectionMode="Single">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:HexDumpRowViewModel">
                <Border Background="{Binding RowBackground}" Padding="6,1" Height="24">
                  <Grid ColumnDefinitions="90,430,*" ColumnSpacing="8">
                    <TextBlock Grid.Column="0"
                               FontFamily="Consolas"
                               FontSize="14"
                               Foreground="#D6DBE6"
                               Text="{Binding OffsetText}" />
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding HexCells}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:HexByteCellViewModel">
                          <Border Margin="0,0,2,0"
                                  Padding="1,0"
                                  Height="20"
                                  Background="{Binding Background}">
                            <TextBlock FontFamily="Consolas"
                                       FontSize="14"
                                       Foreground="{Binding Foreground}"
                                       Text="{Binding Text}" />
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Grid.Column="2"
                               FontFamily="Consolas"
                               FontSize="14"
                               Foreground="#D0D6E1"
                               Text="{Binding AsciiText}" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Margin="10,0,10,10"
            BorderBrush="#404040"
            BorderThickness="1">
      <Grid RowDefinitions="Auto,*">
        <Border BorderBrush="#404040"
                BorderThickness="0,0,0,1"
                Padding="8,6">
          <TextBlock FontWeight="Bold" Text="Byte Differences" />
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="140,120,120"
                Margin="8,6"
                ColumnSpacing="8">
            <TextBlock Grid.Column="0" FontWeight="Bold" Text="Offset" />
            <TextBlock Grid.Column="1" FontWeight="Bold" Text="A" />
            <TextBlock Grid.Column="2" FontWeight="Bold" Text="B" />
          </Grid>

          <ListBox Grid.Row="1"
                   ItemsSource="{Binding Differences}"
                   Background="#171C26"
                   BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ByteDifferenceViewModel">
                <Grid ColumnDefinitions="140,120,120"
                      Margin="8,2"
                      ColumnSpacing="8">
                  <TextBlock Grid.Column="0"
                             FontFamily="Consolas"
                             Foreground="#E8EAF0"
                             Text="{Binding OffsetText}" />
                  <TextBlock Grid.Column="1"
                             FontFamily="Consolas"
                             Foreground="#E8EAF0"
                             Text="{Binding LeftHex}" />
                  <TextBlock Grid.Column="2"
                             FontFamily="Consolas"
                             Foreground="#E8EAF0"
                             Text="{Binding RightHex}" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
