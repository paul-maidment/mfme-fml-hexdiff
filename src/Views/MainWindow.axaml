<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:FmlDiff.ViewModels"
        xmlns:views="using:FmlDiff.Views"
        x:Class="FmlDiff.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        mc:Ignorable="d"
        Title="FML Hex Diff Viewer"
        Width="1600"
        Height="900"
        MinWidth="1200"
        MinHeight="700">
  <Window.Styles>
    <Style Selector="ListBoxItem">
      <Setter Property="Height" Value="24" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#E8EAF0" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:pointerover">
      <Setter Property="Background" Value="#253146" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="#2E5FA8" />
      <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>
    <Style Selector="ListBox.row-selection-suppressed ListBoxItem:selected">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#E8EAF0" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*">
    <Border Grid.Row="0"
            BorderBrush="#404040"
            BorderThickness="0,0,0,1"
            Padding="10">
      <StackPanel Spacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
          <TextBlock VerticalAlignment="Center" Text="File A" />
          <TextBox Grid.Column="1" Text="{Binding FileAPath}" />
          <Button Grid.Column="2"
                  Content="Browse..."
                  Click="OpenFileAClick"
                  IsEnabled="{Binding CanRun}" />
        </Grid>

        <Grid ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
          <TextBlock VerticalAlignment="Center" Text="File B" />
          <TextBox Grid.Column="1" Text="{Binding FileBPath}" />
          <Button Grid.Column="2"
                  Content="Browse..."
                  Click="OpenFileBClick"
                  IsEnabled="{Binding CanRun}" />
        </Grid>

        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*"
              ColumnSpacing="8">
          <Button Grid.Column="0"
                  Content="Load &amp;&amp; Diff"
                  Click="RunDiffClick"
                  IsEnabled="{Binding CanRun}" />
          <Button Grid.Column="1"
                  Content="Previous"
                  Click="PreviousDifferenceClick"
                  IsEnabled="{Binding CanNavigate}" />
          <Button Grid.Column="2"
                  Content="Next"
                  Click="NextDifferenceClick"
                  IsEnabled="{Binding CanNavigate}" />
          <TextBlock Grid.Column="3"
                     VerticalAlignment="Center"
                     Foreground="#E8EAF0"
                     Text="{Binding DifferenceNavigatorText}" />
          <TextBlock Grid.Column="4"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Center"
                     Foreground="#C7CDD8"
                     Text="Changed bytes are highlighted in red" />
        </Grid>

        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto"
              ColumnSpacing="8">
          <TextBlock VerticalAlignment="Center"
                     Foreground="#E8EAF0"
                     Text="Search" />
          <ComboBox Grid.Column="1"
                    Width="90"
                    SelectedIndex="{Binding SearchPaneIndex}">
            <ComboBoxItem Content="Pane A" />
            <ComboBoxItem Content="Pane B" />
          </ComboBox>
          <ComboBox Grid.Column="2"
                    Width="120"
                    SelectedIndex="{Binding SearchModeIndex}">
            <ComboBoxItem Content="UTF-8" />
            <ComboBoxItem Content="UTF-16" />
            <ComboBoxItem Content="Bytes" />
          </ComboBox>
          <TextBox Grid.Column="3"
                   Watermark="Text or hex bytes (e.g. 05 00 00 00)"
                   Text="{Binding SearchText}" />
          <Button Grid.Column="4"
                  Content="Find Prev"
                  Click="FindPreviousSearchClick"
                  IsEnabled="{Binding CanSearchNavigate}" />
          <Button Grid.Column="5"
                  Content="Find Next"
                  Click="FindNextSearchClick"
                  IsEnabled="{Binding CanSearchNavigate}" />
          <TextBlock Grid.Column="6"
                     VerticalAlignment="Center"
                     Foreground="#E8EAF0"
                     Text="{Binding SearchNavigatorText}" />
        </Grid>
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Background="#222A35"
            BorderBrush="#404040"
            BorderThickness="0,0,0,1"
            Padding="8,6">
      <StackPanel Spacing="6">
        <TextBlock Foreground="#E8EAF0" Text="{Binding StatusMessage}" />
        <ProgressBar Minimum="0"
                     Maximum="100"
                     Height="6"
                     IsVisible="{Binding IsBusy}"
                     Value="{Binding LoadingProgress}" />
      </StackPanel>
    </Border>

    <Grid Grid.Row="2"
          ColumnDefinitions="*,*"
          ColumnSpacing="10"
          Margin="10">
      <Border Grid.Column="0"
              BorderBrush="#404040"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,*">
          <Border BorderBrush="#404040"
                  BorderThickness="0,0,0,1"
                  Padding="8,6">
            <TextBlock FontWeight="Bold" Text="Pane A (raw hex)" />
          </Border>

          <ListBox x:Name="LeftListBox"
                   Grid.Row="1"
                   ItemsSource="{Binding RowIndices}"
                   SelectedIndex="{Binding SelectedRowIndex, Mode=TwoWay}"
                   Background="#171C26"
                   BorderThickness="0"
                   SelectionMode="Single"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   views:HexDiffPaneProperties.Presentation="{Binding Presentation}"
                   views:HexDiffPaneProperties.IsLeftPane="True"
                   views:HexDiffPaneProperties.SearchHighlightStart="{Binding SearchHighlightStartCellIndex}"
                   views:HexDiffPaneProperties.SearchHighlightEnd="{Binding SearchHighlightEndCellIndex}">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="x:Int32">
                <views:HexDumpRowControl />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              BorderBrush="#404040"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,*">
          <Border BorderBrush="#404040"
                  BorderThickness="0,0,0,1"
                  Padding="8,6">
            <TextBlock FontWeight="Bold" Text="Pane B (raw hex)" />
          </Border>

          <ListBox x:Name="RightListBox"
                   Grid.Row="1"
                   ItemsSource="{Binding RowIndices}"
                   SelectedIndex="{Binding SelectedRowIndex, Mode=TwoWay}"
                   Background="#171C26"
                   BorderThickness="0"
                   SelectionMode="Single"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   views:HexDiffPaneProperties.Presentation="{Binding Presentation}"
                   views:HexDiffPaneProperties.IsLeftPane="False"
                   views:HexDiffPaneProperties.SearchHighlightStart="{Binding SearchHighlightStartCellIndex}"
                   views:HexDiffPaneProperties.SearchHighlightEnd="{Binding SearchHighlightEndCellIndex}">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <VirtualizingStackPanel />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate DataType="x:Int32">
                <views:HexDumpRowControl />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </Border>
    </Grid>

  </Grid>
</Window>
